generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image     String?
  sequence  Int      @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id                Int                 @id @default(autoincrement())
  name              String
  slug              String              @unique
  productCategoryId Int
  category          ProductCategory     @relation(fields: [productCategoryId], references: [id])
  description       String?             @db.Text
  isActive          Boolean             @default(true)
  images            ProductImage[]
  units             ProductUnitWeight[]
  packages          Package[]
  transactionItems  TransactionItem[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  sequence  Int      @default(0)
}

model ProductUnitWeight {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  price     Decimal  @db.Decimal(10, 2)
  transactionItems TransactionItem[]
}

model Package {
  id        Int      @id @default(autoincrement())
  name      String
  image     String?
  price     Decimal  @db.Decimal(10, 2)
  sequence  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  transactionItems TransactionItem[]
}

model Delivery {
  id             Int      @id @default(autoincrement())
  label          String
  strikeoutPrice Decimal? @db.Decimal(10, 2)
  price          Decimal  @db.Decimal(10, 2)
  sequence       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transactions   Transaction[]
}

model Transaction {
  id              String             @id @default(uuid())
  customerName    String
  customerPhone   String
  customerAddress String             @db.Text
  customerNotes   String?            @db.Text
  lat             Float?
  lng             Float?
  deliveryId      Int
  delivery        Delivery           @relation(fields: [deliveryId], references: [id])
  deliveryPrice   Decimal            @db.Decimal(10, 2)
  totalAmount     Decimal            @db.Decimal(10, 2)
  status          String             @default("Menunggu Konfirmasi")
  items           TransactionItem[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model TransactionItem {
  id            Int       @id @default(autoincrement())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product   @relation(fields: [productId], references: [id])
  unitId        Int
  unit          ProductUnitWeight @relation(fields: [unitId], references: [id])
  packageId     Int?
  package       Package?  @relation(fields: [packageId], references: [id])
  quantity      Int
  price         Decimal   @db.Decimal(10, 2)
  totalPrice    Decimal   @db.Decimal(10, 2)
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  googleMapsUrl String?  @db.Text
  phoneNumber   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
